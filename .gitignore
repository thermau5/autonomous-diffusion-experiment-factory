# Generated artefacts
outputs/
samples/
*.npz

# Exception: track the LaTeX report sources, freeze record, and locked-test
# summary so the report can be regenerated and the contract-freeze evidence
# is in git.
!outputs/
outputs/*
!outputs/paper/
outputs/paper/*
!outputs/paper/*.tex
!outputs/locked_test/
outputs/locked_test/*
!outputs/locked_test/*/
outputs/locked_test/*/*
!outputs/locked_test/*/header.json
!outputs/locked_test/*/summary.json
!outputs/freeze_record.yaml
*.pkl
*.pt
*.ckpt

# External code (vendored or cloned)
third_party/

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
build/
dist/

# Envs
.venv/
.conda/
env/

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp

# Local overrides (kept out of git)
.env
configs/local.*.yaml
